{
  "name": "@agenttrace/dashboard",
  "version": "0.1.0",
  "description": "Local web dashboard for AgentTrace",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --config ../../vitest.config.ts packages/dashboard",
    "start": "node dist/index.js",
    "dashboard": "node dist/index.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "@agenttrace/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "jsdom": "^29.1.1"
  }
}
