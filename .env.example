# AgentTrace Production Environment
# Copy to .env and configure before deployment

# PostgreSQL
POSTGRES_DB=agenttrace
POSTGRES_USER=agenttrace
# REQUIRED: Set a strong password (min 16 chars)
POSTGRES_PASSWORD=

# AgentTrace
# Generate with: openssl rand -hex 32
AGENTTRACE_API_KEY=

# Logging: debug, info, warn, error
LOG_LEVEL=info
