# .env - Production environment variables for AgentTrace
# Copy this to .env and fill in real values before running docker-compose.prod.yml

# ---- PostgreSQL ----
POSTGRES_DB=agenttrace
POSTGRES_USER=agenttrace
# REQUIRED: Set a strong password (min 16 chars)
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD

# ---- AgentTrace Dashboard ----
# Generate with: openssl rand -hex 32
AGENTTRACE_API_KEY=

# ---- Logging ----
LOG_LEVEL=info
