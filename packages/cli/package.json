{
  "name": "@agenttrace-io/cli",
  "version": "0.4.2",
  "description": "CLI for AgentTrace — trace, dashboard, stats, costs, alerts, wrap any agent",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <24.0.0"
  },
  "bin": {
    "agenttrace-io": "./dist/index.js",
    "agenttrace": "./dist/index.js"
  },
  "dependencies": {
    "@agenttrace-io/dashboard": "workspace:*",
    "@agenttrace-io/sdk": "workspace:*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Klepsiphron/agenttrace.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Klepsiphron/agenttrace#readme",
  "keywords": [
    "ai",
    "agents",
    "observability",
    "cli",
    "tracing",
    "llm",
    "cost-tracking"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --config ../../vitest.config.ts packages/cli"
  }
}
