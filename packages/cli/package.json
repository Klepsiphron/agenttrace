{
  "name": "@agenttrace/cli",
  "version": "0.0.0",
  "description": "CLI for AgentTrace — init, dashboard, export, stats",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agenttrace": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --config ../../vitest.config.ts packages/cli"
  }
}
