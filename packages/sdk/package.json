{
  "name": "@agenttrace-io/sdk",
  "version": "0.2.0",
  "description": "Drop-in tracing SDK for AI agents — track tokens, cost, latency, and tool calls",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./benchmark": {
      "types": "./dist/benchmark.d.ts",
      "import": "./dist/benchmark.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Klepsiphron/agenttrace.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Klepsiphron/agenttrace#readme",
  "keywords": [
    "ai",
    "agents",
    "observability",
    "tracing",
    "llm",
    "cost-tracking",
    "token-tracking"
  ],
  "peerDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --config ../../vitest.config.ts packages/sdk"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11"
  }
}
