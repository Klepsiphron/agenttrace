{
  "name": "@agenttrace-io/sdk",
  "version": "0.1.0",
  "description": "Drop-in tracing SDK for AI agents",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./benchmark": {
      "types": "./dist/benchmark.d.ts",
      "import": "./dist/benchmark.js"
    }
  },
  "peerDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": false
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run --config ../../vitest.config.ts packages/sdk"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11"
  }
}
