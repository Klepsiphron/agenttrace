{
  "name": "agenttrace",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source AI agent observability — trace tokens, tools, latency, and cost locally",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "node scripts/sync-version.mjs",
    "build": "pnpm -r run build",
    "pretest": "node scripts/sync-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"packages/**/*.ts\" \"vitest.config.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm -r --parallel run dev",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "better-sqlite3": "^12.10.0",
    "commander": "^15.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8",
    "husky": "^9.1.7"
  }
}
