{
  "name": "agenttrace",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source AI agent observability — trace tokens, tools, latency, and cost locally",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"packages/**/*.ts\" \"vitest.config.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm -r --parallel run dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "better-sqlite3": "^11.7.0",
    "commander": "^15.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.1.3"
  }
}
